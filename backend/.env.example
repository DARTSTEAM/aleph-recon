# Aleph Recon API — Environment Variables
# Copy to .env and fill in values

# Gmail credentials (use App Password, NOT your real Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=finance-ops@alephholding.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Comma-separated list of allowed frontend origins (optional, localhost already included)
ALLOWED_ORIGINS=https://aleph-automation-4772ziyq2a-uc.a.run.app

# Port (Cloud Run sets this automatically)
PORT=8081
