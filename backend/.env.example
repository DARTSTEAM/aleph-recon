# Aleph Recon API v2 — Environment Variables
# Copy to .env and fill in values

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# Generate App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=finance-ops@alephholding.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Auth ──────────────────────────────────────────────────────────────────────
# Optional API key — set in frontend as VITE_API_KEY
API_KEY=

# ── Scheduled jobs (Cloud Scheduler) ─────────────────────────────────────────
# Use a random secret string and configure it in Cloud Scheduler HTTP headers
CRON_SECRET=your-random-cron-secret

# Days before escalating an unresolved Error to the regional director
ESCALATION_DAYS=7

# Days between automatic reminders
REMINDER_DAYS=3

# Email to send escalations and weekly summaries to
ESCALATION_EMAIL=regional-director@alephholding.com
WEEKLY_SUMMARY_EMAIL=regional-director@alephholding.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (localhost already included)
ALLOWED_ORIGINS=https://aleph-automation-4772ziyq2a-uc.a.run.app

# ── Port ──────────────────────────────────────────────────────────────────────
# Cloud Run sets this automatically; only set locally if needed
PORT=8081

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# For scheduled jobs: use Application Default Credentials (ADC) on Cloud Run.
# Locally: set GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
# OR set this to base64-encoded service account JSON:
# GOOGLE_SERVICE_ACCOUNT_B64=...
